    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Actualizar Detalles (Caso de Uso 3)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Nombre Cliente\",\n  \"phone\": \"999888777\"\n}"
            },
            "url": { "raw": "http://localhost:3000/api/users/ID_DEL_USUARIO", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "users", "ID_DEL_USUARIO"] }
          }
        }
      ]
    },
    {
      "name": "Logs",
      "item": [
        {
          "name": "Ver Logs del Parking (Caso de Uso 4)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "http://localhost:3000/api/logs?action=reservation", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "logs"], "query": [{ "key": "action", "value": "reservation" }] }
          }
        }
